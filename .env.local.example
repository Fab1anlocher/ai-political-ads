# API-Konfiguration (nicht committen – nur als Vorlage)
# Kopieren Sie diese Datei als .env.local und tragen Sie Ihre Werte ein

# API-Schlüssel (OpenAI oder Google Gemini)
API_KEY=dein_api_key_hier

# API-Anbieter: "openai" oder "gemini"
API_PROVIDER=openai

# Bildgenerierungsmodell
# OpenAI: "dall-e-3" oder "dall-e-2"
# Gemini: "imagen-3.0-generate-002"
IMAGE_MODEL=dall-e-3
